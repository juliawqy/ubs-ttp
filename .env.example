# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://ubs_ttp:localpassword@postgres:5432/ubs_ttp

# ── AWS (S3 for document storage, SQS for async jobs) ─────────────────────────
# For local dev, LocalStack emulates these — no real AWS needed
AWS_REGION=ap-southeast-1
AWS_ENDPOINT_URL=http://localstack:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
S3_RESUMES_BUCKET=ubs-ttp-resumes
SQS_JOBS_QUEUE_URL=http://localstack:4566/000000000000/ubs-ttp-jobs

# ─── Auth (AWS Cognito) ───────────────────────────────────────────────────────
COGNITO_USER_POOL_ID=ap-southeast-1_XXXXXX
COGNITO_CLIENT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXX
COGNITO_REGION=ap-southeast-1

# ── Frontend ──────────────────────────────────────────────────────────────────
API_URL=http://recruitment:8000
